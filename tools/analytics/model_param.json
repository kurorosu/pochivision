{
  "xgboost": {
    "default_params": {
      "n_estimators": 100,
      "max_depth": 6,
      "learning_rate": 0.1,
      "subsample": 1.0,
      "colsample_bytree": 1.0,
      "reg_alpha": 0,
      "reg_lambda": 1
    },
    "optuna_search_space": {
      "n_estimators": {
        "type": "int",
        "low": 50,
        "high": 300,
        "description": "ブースティングラウンド数"
      },
      "max_depth": {
        "type": "int",
        "low": 3,
        "high": 10,
