      },
      "reg_lambda": {
        "type": "float",
        "low": 1,
        "high": 10,
        "description": "L2正則化項"
      }
    },
    "optuna_config": {
      "default_trials": 100,
      "sampler": "TPESampler",
      "direction": "maximize",
      "cv_folds": 5,
      "scoring": "accuracy"
    }
  },
  "metadata": {
