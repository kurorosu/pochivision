      },
      "learning_rate": {
        "type": "float",
        "low": 0.01,
        "high": 0.3,
        "description": "学習率"
      },
      "subsample": {
        "type": "float",
        "low": 0.6,
        "high": 1.0,
        "description": "サブサンプリング率"
      },
      "colsample_bytree": {
        "type": "float",
        "low": 0.6,
        "high": 1.0,
        "description": "特徴量サンプリング率"
      },
      "reg_alpha": {
        "type": "float",
        "low": 0,
        "high": 10,
