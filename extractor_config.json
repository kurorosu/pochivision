{
  "input_directory": "image_aggregated/20250524_0/pipeline",
  "output_directory": "extraction_results",
  "output_format": "csv",
  "feature_extractors": {
    "brightness": {
      "color_mode": "gray",
      "exclude_zero_pixels": true
    },
    "rgb": {
      "exclude_black_pixels": true
    },
    "hsv": {
      "exclude_black_pixels": true
    },
    "glcm": {
      "distances": [1, 2, 3],
      "angles": [0, 45, 90, 135],
      "levels": 256,
      "symmetric": true,
      "normed": true,
      "properties": [
        "contrast",
        "dissimilarity",
        "homogeneity",
        "energy",
        "correlation",
        "ASM"]
    },
    "fft": {
      "frequency_bands": [
        [0.0, 0.1],
        [0.1, 0.3],
        [0.3, 0.5]
      ],
      "high_low_threshold": 0.2,
      "directional_tolerance": 10.0,
      "peak_threshold_ratio": 0.1,
      "mm_per_pixel": 0.05
    }
  },
  "file_filters": {
    "extensions": [".jpg", ".jpeg", ".png", ".bmp", ".tiff", ".tif"],
    "case_sensitive": false
  },
  "output_settings": {
    "include_filename": true,
    "include_timestamp": true,
    "csv_separator": ",",
    "output_filename": "features.csv"
  }
} 